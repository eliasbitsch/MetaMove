                    <StackPanel DockPanel.Dock="Left" Width="90">
                        <TextBlock TextWrapping="Wrap"><Run Language="de-at" Text="anglePCSDK [°]"/></TextBlock>
                        <TextBlock x:Name="visuRC_PCSDKangle01" TextWrapping="Wrap"><Run Language="de-at" Text="empty"/></TextBlock>
                        <TextBlock x:Name="visuRC_PCSDKangle02" TextWrapping="Wrap"><Run Language="de-at" Text="empty"/></TextBlock>
                        <TextBlock x:Name="visuRC_PCSDKangle03" TextWrapping="Wrap"><Run Language="de-at" Text="empty"/></TextBlock>
                        <TextBlock x:Name="visuRC_PCSDKangle04" TextWrapping="Wrap"><Run Language="de-at" Text="empty"/></TextBlock>
